# 모노레포 루트 — 현장 compose 기준값 (문서·동기용)
# Mongo/JWT/MONGODB_URI 는 docker-compose.integrated.yml · usb485.yml 에 고정됨.
# 아래 MONGO_* · JWT_SECRET 변경 시 compose YAML 도 함께 수정하세요.
# 로컬 pnpm dev: .env.development (별도)
#
# PEOPLE_COUNTER_COUNT 는 ports 마법사가 .env 에 기록 → run-docker-stack 이 export

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=sw-smartcity-db

JWT_SECRET=dev-only-jwt-secret-minimum-32-characters-long

PEOPLE_COUNTER_COUNT=0
# PEOPLE_COUNTER_PORTS=/dev/bushub-people-counter-1
