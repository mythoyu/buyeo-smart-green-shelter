  "scripts": {
    "dev": "pnpm -r run dev",
    "dev:frontend": "pnpm --filter @bushub-client/frontend run dev",
    "dev:backend": "pnpm --filter @bushub-client/backend run dev",
    "dev:people-counter-tester": "pnpm --filter @dev-tools/people-counter-tester run start:dev",
