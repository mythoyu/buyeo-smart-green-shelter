# 모노레포 루트 — 현장 Docker Compose (.env 로 복사)
# cp env.example .env
#
# 개발(pnpm dev): .env.development (이 파일과 분리)

# COMPOSE_PROJECT_NAME=buyeo-smart-green-shelter
GITHUB_REF_NAME=v1.0.0
# install 시 Release 다운로드용 (git 없을 때)
# BUSHUB_INFRA_RELEASE_TAG=v1.0.0

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me-strong-password

JWT_SECRET=change-me-minimum-32-characters-long-secret

PEOPLE_COUNTER_COUNT=0
# PEOPLE_COUNTER_PORTS=/dev/bushub-people-counter-1

# MODBUS_RTSCTS=false

# --- Windows RS-485 (pnpm dev:backend, win32) ---
# cp .env.windows.example .env.windows  → COM 포트·Modbus (baud 9600)

# --- 로컬 pnpm dev (현장 compose 는 3000/8080 유지) ---
# PORT=13031
# VITE_DEV_PORT=15461
# VITE_BACKEND_PORT=13031
# VITE_API_BASE_URL=http://localhost:13031/api/v1
# VITE_WS_URL=ws://localhost:13031/ws
